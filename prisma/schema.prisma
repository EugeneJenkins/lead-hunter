generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(uuid()) @db.Uuid
  source      String
  externalId  String?
  title       String
  description String?
  url         String?
  rawPayload  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source])
}

model TelegramChatCursor {
  chatId        String   @id
  chatRef       String
  title         String?
  lastMessageId Int      @default(0)
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([chatRef])
}
