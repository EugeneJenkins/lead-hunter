generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String   @id @default(uuid()) @db.Uuid
  source      String
  externalId  String?
  title       String
  description String?
  url         String?
  rawPayload  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source])
}

model TelegramChatCursor {
  id            Int      @id @default(autoincrement())
  chatId        String?  @unique
  chatRef       String
  title         String?
  lastMessageId Int      @default(0)
  lastSyncedAt  DateTime @default(now())
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([chatRef])
}

model Job {
  id          String    @id @default(uuid()) @db.Uuid
  type        String
  priority    Int       @default(0)
  payload     Json      @db.Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  runAt       DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  completedAt DateTime?
  failedAt    DateTime?
  lastError   Json?     @db.Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lockedAt, lockedBy], name: "idx_job_locked")
  @@index([status, runAt])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
