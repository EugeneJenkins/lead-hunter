NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://leadhunter:leadhunter@localhost:5432/leadhunter?schema=public

# Comma-separated list. Individual MODULE_ENABLED flags can also enable a module.
ENABLED_MODULES=telegram

TELEGRAM_ENABLED=true
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Comma-separated public usernames, invite links, or numeric chat ids available to the session.
TELEGRAM_CHATS=@example_group,https://t.me/example_channel
TELEGRAM_SYNC_INTERVAL_MS=300000
TELEGRAM_BATCH_SIZE=100
